#Requires dx-macro
#AskAdmin on
#DxHardInput off
#PauseKey F8
#ExitKey ^!x
; #RequireAdmin

#HotIf WinActive("target.exe")

Numpad0::
    Send "{Left}"
    Sleep 80
    Send "{Left}"
    Sleep 80
    Send "{Left}"
Return

NumpadEnter::
    Send "{Right}"
    Sleep 80
    Send "{Right}"
    Sleep 80
    Send "{Right}"
Return

NumpadDot::
    Send "{Down}"
    Sleep 80
    Send "{Right}"
    Sleep 80
    Send "{Right}"
Return
