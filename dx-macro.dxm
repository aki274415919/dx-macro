#InterceptionInstance 1
#InterceptionPid 0x2113
#InterceptionVid 0x413C
#Requires dx-macro
#AskAdmin on
#DxHardInput on
#PauseKey F8
#ExitKey ^!x
; #RequireAdmin

#HotIf WinActive("psobbw.exe")

Numpad0::
    Send "{Left}"
    Sleep 80
    Send "{Left}"
    Sleep 80
    Send "{Left}"
Return

NumpadEnter::
    Send "{Right}"
    Sleep 80
    Send "{Right}"
    Sleep 80
    Send "{Right}"
Return

NumpadDot::
    Send "{Down}"
    Sleep 80
    Send "{Right}"
    Sleep 80
    Send "{Right}"
Return
