#Requires dx-macro
#AskAdmin on
#DxHardInput off
#PauseKey F8
#ExitKey ^!x
; #RequireAdmin

#HotIf WinActive("psobbw.exe")
Numpad1::
    Send "{Down down}"
    Sleep 50
    Send "{Down up}"
    Sleep 100
    Send "{Left down}"
    Sleep 50
    Send "{Left up}"
    Sleep 100
    Send "{Left down}"
    Sleep 50
    Send "{Left up}"
Return
